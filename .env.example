APP_MODE=backtest
MARKET=US

# Symbols separated by commas.
SYMBOLS=AAPL,MSFT

# Strategy params
FAST_WINDOW=20
SLOW_WINDOW=60
STRATEGY_NAME=ma_cross
RSI_WINDOW=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
BB_WINDOW=20
BB_STD=2.0
BREAKOUT_WINDOW=20
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
INITIAL_CAPITAL=100000

# Date range for backtest
START_DATE=2022-01-01
END_DATE=2024-12-31

# Alpaca (US broker)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Futu (HK broker, optional)
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
HK_BROKER=sim

# Live risk and sizing
LIVE_QTY_PER_TRADE=1
MAX_NOTIONAL_PER_TRADE=10000
ALLOW_SHORT=false
ENABLE_MARKET_HOURS_CHECK=true
LIVE_INTERVAL_MINUTES=15
LIVE_MAX_RETRIES=3
ALERT_WEBHOOK_URL=
MIN_BUYING_POWER_BUFFER=100
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.08
MAX_DAILY_LOSS_PCT=0.02
DRY_RUN=false
